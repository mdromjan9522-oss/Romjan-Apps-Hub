{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/api/server.js"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/client/admin/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/client/$1"
    }
  ]
}